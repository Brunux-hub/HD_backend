# Plantilla de variables de entorno del backend (api_healthy_pet).
# Copia este archivo como ".env" y rellena los valores reales (el .env NO se sube a git).
# VS Code lo carga vía "envFile" en .vscode/launch.json.

# --- Conexión a Supabase (Postgres en la nube) ---
# Saca la cadena de: Supabase -> Project Settings -> Database -> Connection string.
# Convierte el prefijo "postgresql://" a "jdbc:postgresql://" y agrega ?sslmode=require.
DATABASE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=<tu-password-de-supabase>

# --- JWT (tiene defaults en application.yaml, opcional sobreescribir) ---
JWT_SECRET=Q2FtYmlhclBvclVuU2VjcmV0b1NlZ3Vyb0RlMzJCeXRlc01pbmltbw==
JWT_EXPIRATION=3600000
